# Agent Brain Benchmarks — environment variables
# Copy this file to .env and fill in your own values.
#
# Usage:
#   cp .env.example .env
#   # edit .env
#   set -a; source .env; set +a
#   python run_full.py

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# Your Brain database (Supabase or self-hosted Postgres with pgvector).
# Must have tables: workspaces, memories. See docs/REPRODUCIBILITY.md.
BRAIN_DB_URL=https://YOUR-PROJECT.supabase.co
BRAIN_DB_SERVICE_KEY=your-service-role-key-here

# OpenAI key for answer generation + GPT-4o judge
OPENAI_API_KEY=sk-proj-...

# -----------------------------------------------------------------------------
# OPTIONAL
# -----------------------------------------------------------------------------

# Brain API endpoint. Default is the hosted evaluation endpoint.
# For local reproduction, point at your own Brain instance.
BRAIN_API_URL=https://api.agentbrain.ch

# OpenRouter (only needed if ANSWER_MODEL is not a GPT-4 variant)
OPENROUTER_API_KEY=

# Models
ANSWER_MODEL=gpt-4o
JUDGE_MODEL=gpt-4o

# Concurrency tuning
MAX_CONCURRENT_STORES=2
MAX_CONCURRENT_RECALLS=10
MAX_CONCURRENT_LLM=5

# Retrieval
RECALL_LIMIT=10
BASELINE_LIMIT=10

# Memory defaults
MEMORY_TYPE=episodic
SOURCE_TRUST=0.9
